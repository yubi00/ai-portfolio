{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    { "src": "/docs", "dest": "/api/docs" },
    { "src": "/openapi.json", "dest": "/api/openapi.json" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/client/dist/$1" }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "memory": 2048
    }
  },
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ]
}
