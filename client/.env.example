# Frontend Environment Variables
VITE_API_URL=http://localhost:9000

# Cloudflare Turnstile site key (required in prod once backend auth is enabled)
VITE_TURNSTILE_SITE_KEY=YOUR_TUNRSTILE_SITE_KEY_HERE

# Dev-only: bypass Turnstile widget and send a dummy token.
# Requires backend `TURNSTILE_BYPASS=1`.
VITE_TURNSTILE_DEV_BYPASS=false

# Dev-only: run Vite dev server over HTTPS to reduce Turnstile/PAT console noise.
# Requires: npm i -D @vitejs/plugin-basic-ssl
VITE_DEV_HTTPS=false

# If true, frontend will fail requests unless it can obtain an access token.
# If false/empty, frontend will try auth but will fall back for older backends (no /auth/*).
VITE_REQUIRE_AUTH=false

# Emergency kill-switch (do not enable in prod)
VITE_DISABLE_AUTH=false
