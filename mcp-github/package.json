{
  "name": "github-mcp-server",
  "version": "1.0.0",
  "description": "GitHub MCP Server for AgentCore Runtime using FastMCP",
  "type": "module",
  "main": "dist/github-server.js",
  "bin": {
    "github-mcp-server": "./dist/github-server.js"
  },
  "scripts": {
    "dev": "tsx watch src/github-server.ts",
    "dev:fastmcp": "fastmcp dev src/github-server.ts",
    "inspect": "fastmcp inspect src/github-server.ts",
    "build": "tsc",
    "start": "node dist/github-server.js",
    "start:agentcore": "cross-env AGENTCORE=true node dist/github-server.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.2",
    "cross-env": "^10.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fastmcp": "^3.14.4",
    "octokit": "^3.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
